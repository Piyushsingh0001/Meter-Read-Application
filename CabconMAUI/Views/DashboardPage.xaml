<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="CabconMAUI.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Dashboard" BackgroundColor="{StaticResource PageBackground}"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto" Padding="22">
        <VerticalStackLayout Grid.Row="0" Spacing="2" Margin="0,36,0,24">
            <Label Text="{Binding WelcomeMessage}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
            <Label Text="{Binding MeterModeLabel}" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
        </VerticalStackLayout>
        <VerticalStackLayout Grid.Row="1" Spacing="14">
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Stroke="{StaticResource CardBorder}">
                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding GoToMeterReadCommand}"/></Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="18" VerticalOptions="Center">
                    <Border BackgroundColor="{StaticResource SectionBg}" StrokeShape="RoundRectangle 12" HeightRequest="52" WidthRequest="52" Grid.Column="0">
                        <Label Text="&#x1F4E1;" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Padding="14,0,0,0" VerticalOptions="Center" Spacing="3">
                        <Label Text="Read Meter" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="Connect and read DLMS meter data" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                    <Label Text="&#x203A;" FontSize="26" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" Grid.Column="2"/>
                </Grid>
            </Border>
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Stroke="{StaticResource CardBorder}">
                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding GoToSettingsCommand}"/></Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="18" VerticalOptions="Center">
                    <Border BackgroundColor="{StaticResource SectionBg}" StrokeShape="RoundRectangle 12" HeightRequest="52" WidthRequest="52" Grid.Column="0">
                        <Label Text="&#x2699;&#xFE0F;" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Padding="14,0,0,0" VerticalOptions="Center" Spacing="3">
                        <Label Text="Settings" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="Port, HDLC, COSEM, security keys" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                    <Label Text="&#x203A;" FontSize="26" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" Grid.Column="2"/>
                </Grid>
            </Border>
        </VerticalStackLayout>
        <Button Grid.Row="2" Text="Logout" Command="{Binding LogoutCommand}"
                Style="{StaticResource OutlineButton}" Margin="0,0,0,12"/>
    </Grid>
</ContentPage>