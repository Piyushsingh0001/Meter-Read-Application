<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:conv="clr-namespace:CabconMAUI.Converters">
    <conv:StringToBoolConverter     x:Key="StringToBoolConverter"/>
    <conv:InvertBoolConverter       x:Key="InvertBoolConverter"/>
    <conv:BoolToErrorColorConverter x:Key="BoolToErrorColorConverter"/>
    <conv:BoolToErrorBgConverter    x:Key="BoolToErrorBgConverter"/>
    <Style x:Key="InputBorder" TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource InputBorderColor}"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 10"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="BackgroundColor" Value="White"/>
    </Style>
    <Style x:Key="FieldLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
    </Style>
    <Style x:Key="SectionHeader" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PrimaryLight}"/>
        <Setter Property="CharacterSpacing" Value="1.5"/>
    </Style>
    <Style x:Key="ReadingLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>
    <Style x:Key="ReadingValue" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="HorizontalOptions" Value="End"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>
    <Style x:Key="ReadingValueAccent" TargetType="Label">
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource ReadingAccent}"/>
        <Setter Property="HorizontalOptions" Value="End"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>
    <Style x:Key="MiniCardLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>
    <Style x:Key="MiniCardValue" TargetType="Label">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource Primary}"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="HeightRequest" Value="50"/>
    </Style>
    <Style x:Key="SuccessButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Success}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HeightRequest" Value="50"/>
    </Style>
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Error}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HeightRequest" Value="50"/>
    </Style>
    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{StaticResource Primary}"/>
        <Setter Property="BorderColor" Value="{StaticResource Primary}"/>
        <Setter Property="BorderWidth" Value="1.5"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HeightRequest" Value="50"/>
    </Style>
    <Style x:Key="WarningButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Warning}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HeightRequest" Value="50"/>
    </Style>
    <Style x:Key="MiniCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource MiniCardBg}"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 10"/>
        <Setter Property="Stroke" Value="{StaticResource CardBorder}"/>
        <Setter Property="Padding" Value="10,8"/>
    </Style>
    <Style x:Key="Divider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="BackgroundColor" Value="{StaticResource DividerColor}"/>
        <Setter Property="Margin" Value="0,5"/>
    </Style>
    <Style x:Key="EntryStyle" TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="Margin" Value="8,0"/>
    </Style>
    <Style x:Key="PickerStyle" TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="TitleColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="Margin" Value="8,0"/>
    </Style>
</ResourceDictionary>